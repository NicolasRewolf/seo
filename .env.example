# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Anthropic
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# GitHub (issues + push)
# ============================================================
GITHUB_TOKEN=
GITHUB_OWNER=NicolasRewolf
GITHUB_REPO=seo

# ============================================================
# Google Search Console — OAuth files (gitignored)
#
# 1. Download OAuth client JSON from GCP → save as gsc-oauth-credentials.json
# 2. Run a one-off consent flow with scope https://www.googleapis.com/auth/webmasters.readonly
#    → save the resulting token (with refresh_token) as gsc-token.json
# ============================================================
GSC_OAUTH_CREDENTIALS_FILE=./gsc-oauth-credentials.json
GSC_TOKEN_FILE=./gsc-token.json
GSC_SITE_URL=https://www.jplouton-avocat.fr/

# ============================================================
# Google Analytics 4 — OAuth files (gitignored)
#
# Same OAuth client as GSC can be reused (file path can match).
# Token MUST be from a separate consent flow that includes scope
# https://www.googleapis.com/auth/analytics.readonly
# ============================================================
GA4_OAUTH_CREDENTIALS_FILE=./gsc-oauth-credentials.json
GA4_TOKEN_FILE=./ga4-token.json
GA4_PROPERTY_ID=

# ============================================================
# Wix (REST API key + site/account IDs)
#
# WIX_API_KEY is the JWT starting with "IST.eyJ..." from Wix Dashboard.
# WIX_ACCOUNT_ID is in the JWT payload (data.tenant.id) — visible at
# Wix Dashboard → Settings → Account Info.
# ============================================================
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=

# ============================================================
# Audit config (overrides Supabase audit_config row if set)
# ============================================================
AUDIT_PERIOD_MONTHS=3
MIN_IMPRESSIONS_THRESHOLD=500
CTR_GAP_THRESHOLD=0.4
POSITION_RANGE_MIN=5
POSITION_RANGE_MAX=15
