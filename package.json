{
  "name": "plouton-seo-audit",
  "version": "0.0.1",
  "description": "REWOLF · Plouton SEO Audit Tool — NavBoost-oriented audit pipeline for jplouton-avocat.fr",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx src/scripts/smoke.ts",
    "crawl": "tsx src/scripts/run-crawl.ts",
    "snapshot": "tsx src/scripts/run-snapshot.ts",
    "audit": "tsx src/scripts/run-audit.ts",
    "audit:loose": "tsx src/scripts/run-audit.ts --ctr-gap=0.3 --min-impressions=200",
    "pull:state": "tsx src/scripts/run-pull-current-state.ts",
    "diagnose": "tsx src/scripts/run-diagnose.ts",
    "fixes": "tsx src/scripts/run-generate-fixes.ts",
    "issues": "tsx src/scripts/run-create-issues.ts",
    "apply": "tsx src/scripts/run-mark-applied.ts",
    "measure": "tsx src/scripts/run-measure.ts",
    "test": "tsx --test src/scripts/test-scoring.ts src/scripts/test-issue-template.ts src/scripts/test-data-quality-check.ts src/scripts/test-content-extractor.ts src/scripts/test-diagnostic-fact-check.ts src/scripts/test-serp-helpers.ts src/scripts/test-google-guidance.ts src/scripts/test-cooked-health.ts",
    "test:scoring": "tsx --test src/scripts/test-scoring.ts",
    "test:issue-template": "tsx --test src/scripts/test-issue-template.ts",
    "test:data-quality": "tsx --test src/scripts/test-data-quality-check.ts",
    "test:content-extractor": "tsx --test src/scripts/test-content-extractor.ts",
    "test:fact-check": "tsx --test src/scripts/test-diagnostic-fact-check.ts",
    "test:serp": "tsx --test src/scripts/test-serp-helpers.ts",
    "test:google": "tsx --test src/scripts/test-google-guidance.ts",
    "test:cooked-health": "tsx --test src/scripts/test-cooked-health.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@octokit/rest": "^21.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.0",
    "googleapis": "^144.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
